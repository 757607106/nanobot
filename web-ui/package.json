{
  "name": "nanobot-web-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:smoke": "vitest run src/smoke/app-smoke.test.tsx",
    "test:e2e:critical": "playwright test --config=playwright.config.ts --grep @critical",
    "test:e2e:a11y": "playwright test --config=playwright.config.ts --grep @a11y",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@ant-design/x": "^1.6.1",
    "@ant-design/x-sdk": "^2.3.0",
    "antd": "^5.27.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.30.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
